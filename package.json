{
  "name": "@loqode/create-vue-starter",
  "version": "0.1.0",
  "description": "Scaffold a VueStarter app — clones the template, creates a Supabase project, runs migrations, and wires up .env in one command.",
  "type": "module",
  "bin": {
    "create-vue-starter": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build",
    "link:local": "npm run build && npm link"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "execa": "^9.5.2",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "vuestarter",
    "nuxt",
    "vue",
    "supabase",
    "starter",
    "template",
    "scaffold"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Loqode/create-vue-starter.git"
  },
  "bugs": {
    "url": "https://github.com/Loqode/create-vue-starter/issues"
  },
  "homepage": "https://github.com/Loqode/create-vue-starter#readme",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  }
}
